# Use public npm registry so EAS Build (and fresh installs) can resolve all packages.
# If you use a different registry locally, you can override with npm config or a local .npmrc.
registry=https://registry.npmjs.org/

# Allow install despite react@19.1.0 vs react-test-renderer@^19.2.4 peer conflict (devDependency only).
# EAS runs "npm ci --include=dev" and will respect this.
legacy-peer-deps=true
